# ==============================================================================
# DEVFORGE PLATFORM ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to '.env' before running any docker compose command.
# Modifying values here allows customization of port mappings, storage volumes,
# credentials, and individual container configurations.
# ==============================================================================

# ------------------------------------------------------------------------------
# GLOBAL PLATFORM CONFIGURATIONS
# ------------------------------------------------------------------------------
# The operational environment for the DevForge platform (development, production)
DEVFORGE_ENV=development

# Name of the bridge network shared by all DevForge services
DEVFORGE_NETWORK_NAME=devforge-network

# ------------------------------------------------------------------------------
# NGINX INGRESS CONTROLLER CONFIGURATIONS
# ------------------------------------------------------------------------------
# Host port mapping for HTTP traffic passing through the Nginx reverse proxy
NGINX_PORT=80

# Host port mapping for HTTPS traffic passing through the Nginx reverse proxy
NGINX_SECURE_PORT=443

# ------------------------------------------------------------------------------
# POSTGRESQL DATABASE CONFIGURATIONS
# ------------------------------------------------------------------------------
# The default database created upon container initialization
POSTGRES_DB=devforge_db

# The administrator/super-user username for PostgreSQL
POSTGRES_USER=postgres_admin

# The administrator/super-user password (MUST change from default in staging/production)
POSTGRES_PASSWORD=SetSecurePasswordHere123!

# Host port mapping for direct PostgreSQL access (useful for local clients)
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# MONGODB CONFIGURATIONS
# ------------------------------------------------------------------------------
# Administrative root username for MongoDB authentication
MONGO_INITDB_ROOT_USERNAME=mongo_admin

# Administrative root password for MongoDB authentication (MUST change)
MONGO_INITDB_ROOT_PASSWORD=SetSecurePasswordHere456!

# Host port mapping for MongoDB access
MONGO_PORT=27017

# ------------------------------------------------------------------------------
# REDIS CONFIGURATIONS
# ------------------------------------------------------------------------------
# Password required to authenticate with the Redis server (MUST change)
REDIS_PASSWORD=SetSecurePasswordHere789!

# Host port mapping for Redis access
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# NEO4J CONFIGURATIONS
# ------------------------------------------------------------------------------
# Authentication credentials format: <username>/<password> (MUST change)
# Disable authentication during initial development with "none", or use custom creds
NEO4J_AUTH=neo4j/SetSecurePasswordHere321!

# Host port mapping for the Neo4j HTTP web interface
NEO4J_PORT_HTTP=7474

# Host port mapping for the Neo4j Bolt protocol (driver connections)
NEO4J_PORT_BOLT=7687

# ------------------------------------------------------------------------------
# QDRANT VECTOR DATABASE CONFIGURATIONS
# ------------------------------------------------------------------------------
# Host port mapping for the Qdrant REST API
QDRANT_PORT=6333

# Host port mapping for the Qdrant gRPC interface
QDRANT_GRPC_PORT=6334

# API Key required for access control (MUST change or leave empty to disable auth)
QDRANT_API_KEY=SetSecureApiKeyHere999!

# ------------------------------------------------------------------------------
# CHROMADB CONFIGURATIONS
# ------------------------------------------------------------------------------
# Host port mapping for the ChromaDB service
CHROMA_PORT=8000

# Authentication token for ChromaDB client validation
CHROMA_AUTH_TOKEN=SetSecureAuthTokenHere888!

# ------------------------------------------------------------------------------
# OLLAMA CONFIGURATIONS
# ------------------------------------------------------------------------------
# Host port mapping for the Ollama API
OLLAMA_PORT=11434

# Internal path inside the container where models are downloaded and stored
OLLAMA_MODELS_PATH=/root/.ollama

# ------------------------------------------------------------------------------
# OPEN WEBUI CONFIGURATIONS
# ------------------------------------------------------------------------------
# Host port mapping for the Open WebUI interface
OPEN_WEBUI_PORT=3000

# Encryption key for signing web sessions/tokens (MUST change, e.g., run `openssl rand -hex 32`)
WEBUI_SECRET_KEY=ReplaceWithLongRandomSecureSecretKeyString

# ==============================================================================
# NODE.JS DEVELOPMENT PORTS
# ==============================================================================
REACT_PORT=5173
NEXTJS_PORT=3001
EXPRESS_PORT=5001
NESTJS_PORT=4000

# ==============================================================================
# PYTHON DEVELOPMENT PORTS
# ==============================================================================
# Port mapping for FastAPI backend development server
FASTAPI_PORT=8081

# Port mapping for Flask backend development server
FLASK_PORT=5002

# Port mapping for Django backend development server
DJANGO_PORT=8082

# Port mapping for JupyterLab workspace environment
JUPYTER_PORT=8888

# ==============================================================================
# AI PLATFORM DEVELOPMENT PORTS
# ==============================================================================
# Port mapping for the custom AI API / LangChain / LlamaIndex developer workspace
AI_PORT=8083

# ==============================================================================
# JAVA PLATFORM DEVELOPMENT PORTS
# ==============================================================================
# Port mapping for Spring Boot development API server
SPRINGBOOT_PORT=8084

# ==============================================================================
# DATABASE WEB MANAGEMENT UIs
# ==============================================================================
# Port mapping and credentials for pgAdmin 4 (PostgreSQL UI)
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@devforge.local
PGADMIN_DEFAULT_PASSWORD=admin

# Port mapping and basic credentials for Mongo Express (MongoDB UI)
MONGO_EXPRESS_PORT=8087
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin

# Port mapping for Redis Commander (Redis UI)
REDIS_COMMANDER_PORT=8086

# ==============================================================================
# INFRASTRUCTURE & OBSERVABILITY CONFIGURATIONS
# ==============================================================================
# Prometheus port mapping
PROMETHEUS_PORT=9090

# Grafana port mapping and admin credentials
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# cAdvisor port mapping
CADVISOR_PORT=8089

# MinIO ports and root credentials
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=minioadmin

# RabbitMQ ports and credentials
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin




