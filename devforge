#!/usr/bin/env bash
# ==============================================================================
# DEVFORGE PLATFORM BASH COMMAND LINE INTERFACE (CLI)
# ==============================================================================
# POSIX-compliant entrypoint to manage the DevForge platform on Linux/macOS/Git Bash.
# v1 commands: up, down, restart, status, logs, shell, create, doctor,
#              backup, restore, seed, build-apk
# v2 commands: new, template, plugin, start, stop, generate, use, update,
#              self-update  (routed to devforge-cli:2.0 container)
# Usage: ./devforge <command> [arguments]
# ==============================================================================

set -euo pipefail

COMMAND=${1:-"help"}

# Helper formatting
print_header() {
    echo -e "\n=== $1 ==="
}

print_success() {
    echo -e "SUCCESS: $1"
}

print_error() {
    echo -e "ERROR: $1"
}

# ==============================================================================
# DEVFORGE v2 — CLI CONTAINER ROUTING
# ==============================================================================
CLI_IMAGE="devforge-cli:2.0"
CLI_DOCKERFILE="docker/cli/Dockerfile"

# Commands handled by the v2 Python CLI engine (inside container)
V2_COMMANDS="new template plugin start stop generate use update self-update init import detect"

# Check if command is a v2 command OR has project/all/help flags
IS_PROJECT_CMD=0
for arg in "$@"; do
    if [[ "$arg" == "--project" ]] || [[ "$arg" == "-p" ]] || [[ "$arg" == "--all" ]] || [[ "$arg" == "-a" ]] || [[ "$arg" == "--help" ]] || [[ "$arg" == "-h" ]]; then
        IS_PROJECT_CMD=1
        break
    fi
done

if echo "$V2_COMMANDS" | grep -qw "$COMMAND" || [ $IS_PROJECT_CMD -eq 1 ]; then

    # Auto-build: detect if CLI image exists, build it automatically if missing
    if ! docker image inspect "$CLI_IMAGE" > /dev/null 2>&1; then
        echo "[DevForge] CLI image '$CLI_IMAGE' not found. Building automatically..."
        docker build -t "$CLI_IMAGE" -f "$CLI_DOCKERFILE" . --quiet
        if [ $? -ne 0 ]; then
            echo "[DevForge] ERROR: Failed to build CLI image. Is Docker running?"
            exit 1
        fi
        echo "[DevForge] CLI image built successfully."
    fi

    # Resolve DevForge root directory (where this script resides)
    DEVFORGE_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"

    # Handle import volume mapping
    IMPORT_VOLUME_OPTS=""
    if [ "$COMMAND" = "import" ] && [ $# -ge 2 ]; then
        IMPORT_PATH="$2"
        # Resolve to absolute path
        if [ -d "$IMPORT_PATH" ]; then
            ABS_IMPORT_PATH=$(cd "$IMPORT_PATH" && pwd)
            IMPORT_VOLUME_OPTS="-v ${ABS_IMPORT_PATH}:/import_target"
        fi
    fi

    # Handle .env file forwarding if present in current directory
    ENV_FILE_OPTS=""
    if [ -f "${PWD}/.env" ]; then
        ENV_FILE_OPTS="--env-file ${PWD}/.env"
    fi

    # Run the CLI engine inside an ephemeral container
    # --rm          : container auto-removes after command completes
    # -it           : interactive terminal (required for questionary wizard)
    # -v PWD        : mounts workspace so generated files appear on host
    # -v docker.sock: allows the CLI to run docker compose commands
    docker run --rm -it \
        -e GROQ_API_KEY \
        -e GEMINI_API_KEY \
        -e OPENAI_API_KEY \
        ${ENV_FILE_OPTS} \
        -v "${PWD}:/workspace" \
        ${IMPORT_VOLUME_OPTS} \
        -v "${DEVFORGE_ROOT}:/devforge" \
        -v "/var/run/docker.sock:/var/run/docker.sock" \
        "$CLI_IMAGE" "$@"

    exit $?
fi


case "$COMMAND" in
    "up")
        print_header "Starting DevForge Services"
        docker compose up -d
        print_success "DevForge is running."
        ;;
    "down")
        print_header "Stopping DevForge Services"
        docker compose down
        print_success "DevForge has stopped."
        ;;
    "restart")
        SERVICE=${2:-""}
        if [ -n "$SERVICE" ]; then
            print_header "Restarting DevForge service '$SERVICE'"
            docker compose restart "$SERVICE"
        else
            print_header "Restarting all DevForge services"
            docker compose restart
        fi
        print_success "Restart complete."
        ;;
    "status")
        print_header "DevForge Container Status"
        docker compose ps
        ;;
    "logs")
        SERVICE=${2:-""}
        if [ -z "$SERVICE" ]; then
            print_error "Please specify a service name. Usage: ./devforge logs <service>"
            exit 1
        fi
        print_header "Output logs for '$SERVICE' (Press Ctrl+C to exit)"
        docker compose logs -f --tail=100 "$SERVICE"
        ;;
    "shell")
        SERVICE=${2:-""}
        if [ -z "$SERVICE" ]; then
            print_error "Please specify a service name. Usage: ./devforge shell <service>"
            exit 1
        fi
        print_header "Opening shell inside container '$SERVICE'"
        docker compose exec "$SERVICE" zsh || docker compose exec "$SERVICE" bash || docker compose exec "$SERVICE" sh
        ;;
    "create")
        TEMPLATE=${2:-""}
        NAME=${3:-""}
        if [ -z "$TEMPLATE" ] || [ -z "$NAME" ]; then
            print_error "Usage: ./devforge create <template> <project_name>"
            echo "Available templates: react, nextjs, express, nestjs, fastapi, flask, django, springboot, flutter, ai"
            exit 1
        fi
        print_header "Scaffolding project '$NAME' from template '$TEMPLATE'"
        if [ -f "scripts/create-$TEMPLATE.sh" ]; then
            bash "./scripts/create-$TEMPLATE.sh" "$NAME"
        else
            print_error "Template '$TEMPLATE' does not exist."
        fi
        ;;
    "doctor")
        print_header "DevForge Diagnostic Doctor"
        
        # Check Docker
        echo -n "Checking Docker daemon status..."
        if docker info >/dev/null 2>&1; then
            echo " [RUNNING]"
        else
            echo " [STOPPED]"
            print_error "Docker daemon is not running."
        fi

        # Check Compose
        echo -n "Checking Compose configuration syntax..."
        if docker compose config -q >/dev/null 2>&1; then
            echo " [VALID]"
        else
            echo " [INVALID]"
            docker compose config
        fi
        ;;
    "backup")
        print_header "Executing database backups"
        bash "./scripts/db-backup.sh"
        ;;
    "restore")
        FOLDER=${2:-""}
        if [ -z "$FOLDER" ]; then
            print_error "Please specify a backup directory. Usage: ./devforge restore backups/YYYYMMDD_HHMMSS"
            exit 1
        fi
        print_header "Restoring databases from snapshot '$FOLDER'"
        bash "./scripts/db-restore.sh" "$FOLDER"
        ;;
    "seed")
        print_header "Seeding active databases"
        bash "./scripts/db-seed.sh"
        ;;
    "build-apk")
        print_header "Compiling Flutter release APK"
        FLUTTER_PATH=""
        if [ -f "pubspec.yaml" ]; then
            FLUTTER_PATH="pubspec.yaml"
        elif [ -f "projects/sample-flutter/pubspec.yaml" ]; then
            FLUTTER_PATH="projects/sample-flutter/pubspec.yaml"
        else
            FLUTTER_PATH=$(find . -name "pubspec.yaml" -not -path '*/.*' -not -path '*/node_modules/*' -not -path '*/build/*' -not -path '*/.venv/*' | head -n 1)
        fi

        if [ -z "$FLUTTER_PATH" ]; then
            print_error "No Flutter project (pubspec.yaml) found in the current directory or subdirectories."
            exit 1
        fi

        FLUTTER_DIR=$(dirname "$FLUTTER_PATH")
        ABS_FLUTTER_DIR=$(cd "$FLUTTER_DIR" && pwd)
        echo "Found Flutter project at: $ABS_FLUTTER_DIR"

        FLUTTER_IMAGE="devforge-flutter"
        if ! docker image inspect "$FLUTTER_IMAGE" > /dev/null 2>&1; then
            DEVFORGE_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
            echo "[DevForge] Flutter compiler image '$FLUTTER_IMAGE' not found. Building automatically..."
            docker build -t "$FLUTTER_IMAGE" -f "$DEVFORGE_ROOT/docker/flutter/Dockerfile" "$DEVFORGE_ROOT"
            if [ $? -ne 0 ]; then
                print_error "Failed to build Flutter compiler image."
                exit 1
            fi
            echo "[DevForge] Flutter compiler image built successfully."
        fi

        docker run --rm \
            -v "${ABS_FLUTTER_DIR}:/workspace" \
            -w /workspace \
            -v "devforge_gradle_cache:/home/devforge/.gradle" \
            -v "devforge_pub_cache:/home/devforge/.pub-cache" \
            "$FLUTTER_IMAGE" bash -c "flutter pub get && flutter build apk --release"

        if [ $? -ne 0 ]; then
            print_error "Failed to compile Flutter release APK."
            exit 1
        fi
        print_success "APK compilation finished."
        ;;
    "build")
        SUB=${2:-""}
        if [ "$SUB" = "apk" ]; then
            print_header "Compiling Flutter release APK"
            FLUTTER_PATH=""
            if [ -f "pubspec.yaml" ]; then
                FLUTTER_PATH="pubspec.yaml"
            elif [ -f "projects/sample-flutter/pubspec.yaml" ]; then
                FLUTTER_PATH="projects/sample-flutter/pubspec.yaml"
            else
                FLUTTER_PATH=$(find . -name "pubspec.yaml" -not -path '*/.*' -not -path '*/node_modules/*' -not -path '*/build/*' -not -path '*/.venv/*' | head -n 1)
            fi

            if [ -z "$FLUTTER_PATH" ]; then
                print_error "No Flutter project (pubspec.yaml) found in the current directory or subdirectories."
                exit 1
            fi

            FLUTTER_DIR=$(dirname "$FLUTTER_PATH")
            ABS_FLUTTER_DIR=$(cd "$FLUTTER_DIR" && pwd)
            echo "Found Flutter project at: $ABS_FLUTTER_DIR"

            FLUTTER_IMAGE="devforge-flutter"
            if ! docker image inspect "$FLUTTER_IMAGE" > /dev/null 2>&1; then
                DEVFORGE_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
                echo "[DevForge] Flutter compiler image '$FLUTTER_IMAGE' not found. Building automatically..."
                docker build -t "$FLUTTER_IMAGE" -f "$DEVFORGE_ROOT/docker/flutter/Dockerfile" "$DEVFORGE_ROOT"
                if [ $? -ne 0 ]; then
                    print_error "Failed to build Flutter compiler image."
                    exit 1
                fi
                echo "[DevForge] Flutter compiler image built successfully."
            fi

            docker run --rm \
                -v "${ABS_FLUTTER_DIR}:/workspace" \
                -w /workspace \
                -v "devforge_gradle_cache:/home/devforge/.gradle" \
                -v "devforge_pub_cache:/home/devforge/.pub-cache" \
                "$FLUTTER_IMAGE" bash -c "flutter pub get && flutter build apk --release"

            if [ $? -ne 0 ]; then
                print_error "Failed to compile Flutter release APK."
                exit 1
            fi
            print_success "APK compilation finished."
        else
            print_header "Building custom DevForge images"
            docker compose build
            print_success "Build complete."
        fi
        ;;
    *)
        if [ "$COMMAND" != "help" ] && [ "$COMMAND" != "commands" ] && [ -n "$COMMAND" ]; then
            print_error "Unknown command '$COMMAND'\n"
        fi
        echo "DevForge local developer platform CLI"
        echo "Usage: ./devforge <command> [arguments]"
        
        echo -e "\nProject-aware Commands (v2):"
        echo "  new              Create a new project interactively"
        echo "  init             Initialize the current directory as a project"
        echo "  import <path>    Import an existing project from another directory"
        echo "  detect           Scan the current project for technologies"
        echo "  template         Manage code templates"
        echo "  plugin           Manage service plugins (list, install, remove, create)"
        echo "  use <project>    Set the active project for subsequent commands"
        echo "  start <svc>      Start a specific project service"
        echo "  stop <svc>       Stop a specific project service"
        echo "  restart <svc>    Restart a specific project service"
        echo "  logs <svc>       Tail logs for a project service"
        echo "  shell <svc>      Open a shell inside a project service container"
        echo "  update           Update the DevForge CLI image"

        echo -e "\nPlatform-wide Commands (v1):"
        echo "  up               Start all platform services"
        echo "  down             Stop all platform services"
        echo "  restart          Restart all platform services"
        echo "  status           Show running platform containers status"
        echo "  logs             View tailing logs for platform services"
        echo "  shell            Open interactive terminal inside a platform container"
        echo "  create <t> <n>   Scaffold a standalone template project"
        echo "  doctor           Run platform health diagnostics"
        echo "  backup           Back up platform databases"
        echo "  restore <f>      Restore database state from snapshot folder <f>"
        echo "  seed             Populate databases with starter data"
        echo "  build            Build custom DevForge platform images"
        echo "  build apk        Compile Flutter Android APK release target"
        ;;
esac
