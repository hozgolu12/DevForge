#!/usr/bin/env bash
# ==============================================================================
# DEVFORGE PLATFORM BASH COMMAND LINE INTERFACE (CLI)
# ==============================================================================
# POSIX-compliant entrypoint to manage the DevForge platform on Linux/macOS/Git Bash.
# v1 commands: up, down, restart, status, logs, shell, create, doctor,
#              backup, restore, seed, build-apk
# v2 commands: new, template, plugin, start, stop, generate, use, update,
#              self-update  (routed to devforge-cli:2.0 container)
# Usage: ./devforge <command> [arguments]
# ==============================================================================

set -euo pipefail

COMMAND=${1:-"help"}

# Helper formatting
print_header() {
    echo -e "\n=== $1 ==="
}

print_success() {
    echo -e "SUCCESS: $1"
}

print_error() {
    echo -e "ERROR: $1"
}

# ==============================================================================
# DEVFORGE v2 — CLI CONTAINER ROUTING
# ==============================================================================
CLI_IMAGE="devforge-cli:2.0"
CLI_DOCKERFILE="docker/cli/Dockerfile"

# Commands handled by the v2 Python CLI engine (inside container)
V2_COMMANDS="new template plugin start stop generate use update self-update init import detect"

if echo "$V2_COMMANDS" | grep -qw "$COMMAND"; then

    # Auto-build: detect if CLI image exists, build it automatically if missing
    if ! docker image inspect "$CLI_IMAGE" > /dev/null 2>&1; then
        echo "[DevForge] CLI image '$CLI_IMAGE' not found. Building automatically..."
        docker build -t "$CLI_IMAGE" -f "$CLI_DOCKERFILE" . --quiet
        if [ $? -ne 0 ]; then
            echo "[DevForge] ERROR: Failed to build CLI image. Is Docker running?"
            exit 1
        fi
        echo "[DevForge] CLI image built successfully."
    fi

    # Resolve DevForge root directory (where this script resides)
    DEVFORGE_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"

    # Handle import volume mapping
    IMPORT_VOLUME_OPTS=""
    if [ "$COMMAND" = "import" ] && [ $# -ge 2 ]; then
        IMPORT_PATH="$2"
        # Resolve to absolute path
        if [ -d "$IMPORT_PATH" ]; then
            ABS_IMPORT_PATH=$(cd "$IMPORT_PATH" && pwd)
            IMPORT_VOLUME_OPTS="-v ${ABS_IMPORT_PATH}:/import_target"
        fi
    fi

    # Run the CLI engine inside an ephemeral container
    # --rm          : container auto-removes after command completes
    # -it           : interactive terminal (required for questionary wizard)
    # -v PWD        : mounts workspace so generated files appear on host
    # -v docker.sock: allows the CLI to run docker compose commands
    docker run --rm -it \
        -v "${PWD}:/workspace" \
        ${IMPORT_VOLUME_OPTS} \
        -v "${DEVFORGE_ROOT}:/devforge" \
        -v "/var/run/docker.sock:/var/run/docker.sock" \
        "$CLI_IMAGE" "$@"

    exit $?
fi


case "$COMMAND" in
    "up")
        print_header "Starting DevForge Services"
        docker compose up -d
        print_success "DevForge is running."
        ;;
    "down")
        print_header "Stopping DevForge Services"
        docker compose down
        print_success "DevForge has stopped."
        ;;
    "restart")
        SERVICE=${2:-""}
        if [ -n "$SERVICE" ]; then
            print_header "Restarting DevForge service '$SERVICE'"
            docker compose restart "$SERVICE"
        else
            print_header "Restarting all DevForge services"
            docker compose restart
        fi
        print_success "Restart complete."
        ;;
    "status")
        print_header "DevForge Container Status"
        docker compose ps
        ;;
    "logs")
        SERVICE=${2:-""}
        if [ -z "$SERVICE" ]; then
            print_error "Please specify a service name. Usage: ./devforge logs <service>"
            exit 1
        fi
        print_header "Output logs for '$SERVICE' (Press Ctrl+C to exit)"
        docker compose logs -f --tail=100 "$SERVICE"
        ;;
    "shell")
        SERVICE=${2:-""}
        if [ -z "$SERVICE" ]; then
            print_error "Please specify a service name. Usage: ./devforge shell <service>"
            exit 1
        fi
        print_header "Opening shell inside container '$SERVICE'"
        docker compose exec "$SERVICE" zsh || docker compose exec "$SERVICE" bash || docker compose exec "$SERVICE" sh
        ;;
    "create")
        TEMPLATE=${2:-""}
        NAME=${3:-""}
        if [ -z "$TEMPLATE" ] || [ -z "$NAME" ]; then
            print_error "Usage: ./devforge create <template> <project_name>"
            echo "Available templates: react, nextjs, express, nestjs, fastapi, flask, django, springboot, flutter, ai"
            exit 1
        fi
        print_header "Scaffolding project '$NAME' from template '$TEMPLATE'"
        if [ -f "scripts/create-$TEMPLATE.sh" ]; then
            bash "./scripts/create-$TEMPLATE.sh" "$NAME"
        else
            print_error "Template '$TEMPLATE' does not exist."
        fi
        ;;
    "doctor")
        print_header "DevForge Diagnostic Doctor"
        
        # Check Docker
        echo -n "Checking Docker daemon status..."
        if docker info >/dev/null 2>&1; then
            echo " [RUNNING]"
        else
            echo " [STOPPED]"
            print_error "Docker daemon is not running."
        fi

        # Check Compose
        echo -n "Checking Compose configuration syntax..."
        if docker compose config -q >/dev/null 2>&1; then
            echo " [VALID]"
        else
            echo " [INVALID]"
            docker compose config
        fi
        ;;
    "backup")
        print_header "Executing database backups"
        bash "./scripts/db-backup.sh"
        ;;
    "restore")
        FOLDER=${2:-""}
        if [ -z "$FOLDER" ]; then
            print_error "Please specify a backup directory. Usage: ./devforge restore backups/YYYYMMDD_HHMMSS"
            exit 1
        fi
        print_header "Restoring databases from snapshot '$FOLDER'"
        bash "./scripts/db-restore.sh" "$FOLDER"
        ;;
    "seed")
        print_header "Seeding active databases"
        bash "./scripts/db-seed.sh"
        ;;
    "build-apk")
        print_header "Compiling Flutter release APK"
        docker compose exec flutter flutter build apk --release
        print_success "APK compilation finished."
        ;;
    *)
        echo "DevForge local developer platform CLI"
        echo "Usage: ./devforge <command> [arguments]"
        echo -e "\nAvailable Commands:"
        echo "  up               Start all DevForge services"
        echo "  down             Stop all DevForge services"
        echo "  restart [svc]    Restart a specific or all services"
        echo "  status           Show running containers status"
        echo "  logs <svc>       View tailing logs for a service"
        echo "  shell <svc>      Open interactive terminal inside a container"
        echo "  create <t> <n>   Generate project <n> from template <t>"
        echo "  doctor           Run platform health diagnostics"
        echo "  backup           Back up active databases"
        echo "  restore <f>      Restore database state from snapshot folder <f>"
        echo "  seed             Populate databases with starter data"
        echo "  build-apk        Compile Flutter Android APK release target"
        ;;
esac
